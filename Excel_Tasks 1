Workbook = Param.Workbook
excel_sheet = Workbook.GetSheet("Sheet1")
cells = excel_sheet.Cells
lastcell = str(cells.GetLastColumnPosition)+str(cells.GetRowCount)
data = cells.GetRange("A1", lastcell)
cont = Product.GetContainerByName("CONATINER 2")
for i in range(1, len(data)):
    if not data[i,0] and not data[i,1] and not data[i,2]:
        continue
 
    Log.Info(str(i))
    newRow = cont.AddNewRow(False)
    newRow['BRAND'] = data[i,0]
    newRow['MODEL'] = data[i,1]
    newRow['STORAGE'] = data[i,2]
